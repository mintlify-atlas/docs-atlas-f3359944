  "keyFeatures": [
    "Type-safe error handling with comprehensive error tracking",
    "First-class concurrency with fibers and structured concurrency",
    "Dependency injection through Context and Layer system",
    "Resource safety with automatic cleanup and interruption",
    "Streaming data processing with backpressure support",
    "Built-in testing utilities and property-based testing",
    "OpenTelemetry integration for observability",
    "Cross-platform runtime utilities for Node.js, Bun, and browsers"
  ],
  "publicApiSurface": [
    "Effect - Core effect type and operations",
    "Option - Type-safe optional values",
    "Either - Error handling with typed errors",
    "Array - Functional array operations",
    "Stream - Streaming data processing",
    "Schema - Runtime type validation and transformation",
    "Layer - Dependency injection and service construction",
    "Fiber - Lightweight concurrent execution",
    "Ref - Concurrent mutable state",
    "Queue - Asynchronous queues with backpressure",
    "Schedule - Composable retry and repeat policies",
    "Deferred - Promise-like concurrent primitives",
    "Context - Dependency injection container",
    "Cause - Structured error representation",
    "Exit - Effect completion representation",
    "Runtime - Effect execution environment",
    "Chunk - Immutable array-like structure",
    "HashMap - Immutable hash-based map",
    "HashSet - Immutable hash-based set",
    "Duration - Time duration operations",
    "DateTime - Date and time utilities",
    "Clock - Time service abstraction",
    "Console - Console operations as effects",
    "Random - Random value generation",
    "Metric - Application metrics collection",
    "Logger - Structured logging",
    "Config - Configuration management",
    "Brand - Branded types for type safety",
    "Data - Algebraic data types",
    "Match - Pattern matching utilities"
  ]
